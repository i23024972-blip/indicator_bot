# Copy this file to ".env" and fill in your own values. The real .env is git-ignored.
#
# 1. Open @BotFather in Telegram, send /newbot (or /token for an existing bot),
#    and paste the token it gives you below.
# 2. Get your CHAT_ID by messaging @userinfobot in Telegram.
#
TELEGRAM_TOKEN=your-telegram-bot-token-here
CHAT_ID=your-numeric-chat-id-here
